{
  "$schema": "https://registry.codepulse.dev/v1/scanner.schema.json",
  "id": "scn.factory-droid",
  "version": "0.9.1",
  "displayName": "Droid (Factory)",
  "publisher": "code-pulse-official",
  "trust": "verified",
  "enabled": true,
  "minDaemon": "0.9.0",
  "minProtocol": "5.1",
  "capabilities": [
    "process",
    "log",
    "hook"
  ],
  "processPatterns": [
    "droid",
    "Droid"
  ],
  "logPaths": [
    {
      "glob": "~/.factory/sessions/**/*.jsonl",
      "parser": "generic-ndjson-v1",
      "watchMode": "tail"
    }
  ],
  "hookInstaller": {
    "configPath": "~/.factory/hooks.json",
    "forwarder": "~/.codepulse/hooks/droid-forward.sh",
    "events": [
      "PreToolUse",
      "PostToolUse",
      "SessionEnd"
    ]
  },
  "fileChangeTools": [
    "Write",
    "Edit",
    "Bash"
  ],
  "allowedFields": [
    "session_id",
    "tool_name",
    "duration_ms",
    "token_counts",
    "file_path_hash"
  ],
  "redactedFields": [
    "prompt",
    "response",
    "tool_input"
  ],
  "contentPolicy": "metadata-only",
  "signature": "1Z/Iexcv508C8xfVHvBLaMBo96cWFeDgO3hDxQlhn6irlZcWaZ6IcuU/R8Y7X/4TO8jS3KcJ+U8mlD/0i/i2CQ==",
  "bundleHash": "aee7ef2d2953beed87d12b462fedca5fb8b993dae75b89f0a6f2c8b962e4c145"
}
