{
  "$schema": "https://registry.codepulse.dev/v1/scanner.schema.json",
  "id": "scn.kilo",
  "version": "1.0.0",
  "displayName": "Kilo",
  "publisher": "code-pulse-official",
  "trust": "official",
  "enabled": true,
  "minDaemon": "0.9.0",
  "minProtocol": "5.1",
  "capabilities": [
    "process",
    "log",
    "lm"
  ],
  "processPatterns": [
    "kilo",
    "Kilo"
  ],
  "logPaths": [
    {
      "glob": "~/.kilo/logs/**/*.jsonl",
      "parser": "generic-ndjson-v1",
      "watchMode": "tail"
    }
  ],
  "tokenFields": {
    "input": "input_tokens",
    "output": "output_tokens",
    "model": "model"
  },
  "allowedFields": [
    "session_id",
    "tool_name",
    "duration_ms",
    "token_counts"
  ],
  "redactedFields": [
    "prompt",
    "response",
    "content"
  ],
  "contentPolicy": "metadata-only",
