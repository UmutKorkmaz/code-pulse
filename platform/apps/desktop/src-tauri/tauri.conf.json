{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Code Pulse",
  "version": "0.1.0",
  "identifier": "dev.codepulse.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Code Pulse",
        "width": 1100,
        "height": 720,
        "minWidth": 360,
        "minHeight": 480,
        "resizable": true,
        "useHttpsScheme": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}